generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
}

model User {
  id          Int       @id @default(autoincrement())

  name        String
  email       String    @unique
  password    String

  role        Role      @default(admin)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

//////////////////////////////////////////////////
// HERO SECTION
//////////////////////////////////////////////////

model Hero {
  id            Int       @id @default(autoincrement())

  name          String
  title         String
  subtitle      String?

  description   String?

  profileImage  String?

  resumeUrl     String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

//////////////////////////////////////////////////
// ABOUT SECTION
//////////////////////////////////////////////////

model About {
  id            Int       @id @default(autoincrement())

  heading       String
  content       String

  image         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

//////////////////////////////////////////////////
// SKILLS SECTION
//////////////////////////////////////////////////

model Skill {
  id            Int       @id @default(autoincrement())

  name          String

  category      String

  level         Int?

  icon          String?

  description   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

//////////////////////////////////////////////////
// PROJECTS SECTION
//////////////////////////////////////////////////

model Project {
  id              Int       @id @default(autoincrement())

  title           String

  slug            String    @unique

  shortDescription String

  longDescription String?

  image           String?

  githubUrl       String?

  liveUrl         String?

  featured        Boolean   @default(false)

  techStack       String[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

//////////////////////////////////////////////////
// EXPERIENCE SECTION
//////////////////////////////////////////////////

model Experience {
  id                Int       @id @default(autoincrement())

  company           String

  role              String

  location          String?

  description       String?

  startDate         DateTime

  endDate           DateTime?

  currentlyWorking  Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

//////////////////////////////////////////////////
// EDUCATION SECTION
//////////////////////////////////////////////////

model Education {
  id            Int       @id @default(autoincrement())

  institution   String

  degree        String

  field         String?

  grade         String?

  startYear     Int?

  endYear       Int?

  description   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

//////////////////////////////////////////////////
// CERTIFICATES SECTION
//////////////////////////////////////////////////

model Certificate {
  id            Int       @id @default(autoincrement())

  title         String

  issuer        String

  issueDate     DateTime?

  credentialUrl String?

  image         String?

  createdAt     DateTime  @default(now())
}

//////////////////////////////////////////////////
// ACHIEVEMENTS SECTION
//////////////////////////////////////////////////

model Achievement {
  id            Int       @id @default(autoincrement())

  title         String

  description   String

  createdAt     DateTime  @default(now())
}

//////////////////////////////////////////////////
// SOCIAL LINKS
//////////////////////////////////////////////////

model SocialLink {
  id            Int       @id @default(autoincrement())

  platform      String

  url           String

  icon          String?

  createdAt     DateTime  @default(now())
}

//////////////////////////////////////////////////
// CONTACT MESSAGES
//////////////////////////////////////////////////

model ContactMessage {
  id            Int       @id @default(autoincrement())

  name          String

  email         String

  subject       String?

  message       String

  isRead        Boolean   @default(false)

  createdAt     DateTime  @default(now())
}

//////////////////////////////////////////////////
// TERMINAL COMMANDS
//////////////////////////////////////////////////

model TerminalCommand {
  id            Int       @id @default(autoincrement())

  command       String    @unique

  response      String

  createdAt     DateTime  @default(now())
}

model Resume {
  id        Int      @id @default(autoincrement())

  title     String
  fileUrl   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}